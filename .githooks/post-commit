#!/bin/bash

# Only run on the main branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ]; then
    exit 0
fi

# Prevent infinite loop by checking if the last commit already has the bumped version string
LAST_MSG=$(git log -1 --pretty=%B)
if [[ "$LAST_MSG" == *\ -\ bumped\ to\ v* ]]; then
    exit 0
fi

echo ""
echo "====================================================="
echo " post-commit hook: Auto-bumping version on main... "
echo "====================================================="
./scripts/generate-tag.sh patch --amend --push
