{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Indyz POS",
  "version": "0.1.22",
  "identifier": "com.indyz.ai.pos",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Indyz POS",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": [
        "indyzai-pos"
      ],
      "domains": [
        "auth.indyzai.com",
        "pos.indyzai.com"
      ]
    },
    "sql": {
      "preloadedDatabases": [
        "sqlite:pos_db.sqlite"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.macOS.plist"
    },
    "iOS": {
      "developmentTeam": "$APPLE_TEAM_ID"
    }
  }
}
